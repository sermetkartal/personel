# ─── Admin API ───────────────────────────────────────────────────────────────
# Base URL of the Personel Admin API (proxied via Envoy on-prem)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# ─── Keycloak OIDC ────────────────────────────────────────────────────────────
# Keycloak server URL (public — used for browser redirects)
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8180
# Keycloak realm
NEXT_PUBLIC_KEYCLOAK_REALM=personel
# Keycloak client ID (public PKCE client — no client secret)
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=personel-console

# ─── LiveKit ─────────────────────────────────────────────────────────────────
# LiveKit WebSocket server URL (served via Envoy)
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880

# ─── MinIO (for image domains) ───────────────────────────────────────────────
MINIO_HOSTNAME=minio.personel.local

# ─── Session ─────────────────────────────────────────────────────────────────
# Secret used to sign the HTTP-only session cookie (min 32 chars)
SESSION_SECRET=change-me-in-production-minimum-32-chars

# ─── OpenTelemetry ───────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=personel-console
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ─── Next.js ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_VERSION=0.1.0
