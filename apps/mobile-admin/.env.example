# Expo
APP_VARIANT=development
EAS_PROJECT_ID=REPLACE_WITH_EAS_PROJECT_ID

# Mobile BFF — the Go service that proxies to the Admin API and manages push tokens
# Never expose the Admin API directly to the mobile app.
MOBILE_BFF_URL=https://mobile-bff.internal.yourdomain.com

# Keycloak OIDC — same realm as the Admin Console
KEYCLOAK_URL=https://auth.internal.yourdomain.com
KEYCLOAK_REALM=personel
KEYCLOAK_CLIENT_ID=personel-mobile-admin

# Android push (FCM) — only needed at build time for EAS Build
# GOOGLE_SERVICES_JSON=./google-services.json

# iOS push (APNs) — configured in EAS secrets, not here
# APNs key is managed in the EAS dashboard, not in .env

# EAS Update channel — set per build profile in eas.json
# EAS_UPDATE_CHANNEL=production
