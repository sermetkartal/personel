# Personel Employee Transparency Portal — Environment Variables
# Copy this file to .env.local and fill in values for your deployment.

# ─────────────────────────────────────────────────────────────────────────────
# API
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the Personel Admin API (server-to-server, internal network)
PERSONEL_API_BASE_URL=http://api:8080

# ─────────────────────────────────────────────────────────────────────────────
# Keycloak SSO
# ─────────────────────────────────────────────────────────────────────────────

# OIDC Discovery / Issuer URL
KEYCLOAK_ISSUER=https://keycloak.musteri.com.tr/realms/personel

# OAuth2 client credentials for the portal
KEYCLOAK_CLIENT_ID=personel-portal
KEYCLOAK_CLIENT_SECRET=changeme

# Where Keycloak redirects after login
NEXT_PUBLIC_BASE_URL=https://personel-portal.musteri.com.tr

# ─────────────────────────────────────────────────────────────────────────────
# Session
# ─────────────────────────────────────────────────────────────────────────────

# 32+ character random string — used to seal the session cookie
SESSION_SECRET=replace-with-at-least-32-char-random-string

# Session cookie max age in seconds (default: 8 hours)
SESSION_MAX_AGE=28800

# ─────────────────────────────────────────────────────────────────────────────
# Portal settings
# ─────────────────────────────────────────────────────────────────────────────

# Default locale (tr | en)
NEXT_PUBLIC_DEFAULT_LOCALE=tr

# Customer-specific display name shown in the portal header
NEXT_PUBLIC_COMPANY_NAME=Şirketiniz

# DPO contact email shown on the contact page
NEXT_PUBLIC_DPO_EMAIL=kvkk@musteri.com.tr

# Portal support URL (optional — used in error states)
NEXT_PUBLIC_SUPPORT_URL=
