<?xml version="1.0" encoding="UTF-8"?>
<!--
  Personel Platform — Keycloak Infinispan Cache Config
  Faz 5 Madde 52 — Keycloak 2-node HA

  Discovery: JDBC_PING2 via the shared Postgres `keycloak` database. Nodes
  register themselves in the ping_data table and read each other's entries
  on startup; no multicast, no extra network ports (works on the pilot LAN
  + future SaaS container networks).

  Transport: TCP with TLS2. The per-node cert issued from Vault PKI
  (server-cert role) is used for both transport encryption and mTLS node
  authentication.

  Distributed caches: sessions, client sessions, offline sessions, offline
  client sessions, action tokens, login failures, authentication sessions,
  work. Owners=2 ensures every entry is replicated to both nodes — when one
  dies the other still serves the session.

  Replicated caches: realms, users, keys, authorization, crl. These are
  small, read-heavy, and benefit from full replication.
-->
<infinispan
    xmlns="urn:infinispan:config:14.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="urn:infinispan:config:14.0 https://infinispan.org/schemas/infinispan-config-14.0.xsd">

    <jgroups>
        <stack name="jdbc-ping-tcp" extends="tcp">
            <TCP
                bind_addr="${jgroups.bind.address:SITE_LOCAL}"
                bind_port="${jgroups.bind.port:7800}"
                enable_diagnostics="false"
                thread_naming_pattern="pl"
                send_buf_size="640k"
                sock_conn_timeout="300"/>

            <JDBC_PING2
                stack.combine="REPLACE"
                stack.position="MPING"
                connection_driver="org.postgresql.Driver"
                connection_url="${env.KC_DB_URL_JGROUPS}"
                connection_username="${env.KC_DB_USERNAME}"
                connection_password="${env.KC_DB_PASSWORD}"
                initialize_sql="CREATE TABLE IF NOT EXISTS jgroups_ping (own_addr VARCHAR(200) NOT NULL, cluster_name VARCHAR(200) NOT NULL, bind_addr VARCHAR(200) NOT NULL, updated TIMESTAMP DEFAULT CURRENT_TIMESTAMP, ping_data BYTEA DEFAULT NULL, CONSTRAINT PK_jgroups_ping PRIMARY KEY (own_addr, cluster_name))"
                remove_all_data_on_view_change="true"
                register_shutdown_hook="false"
                stack_combine="REPLACE"
                stack_position="MPING"/>
        </stack>
    </jgroups>

    <cache-container name="keycloak">
        <transport lock-timeout="60000" stack="jdbc-ping-tcp"/>

        <!-- Local caches (per-node, not clustered) -->
        <local-cache name="realms">
            <encoding>
                <key media-type="application/x-java-object"/>
                <value media-type="application/x-java-object"/>
            </encoding>
            <memory max-count="10000"/>
        </local-cache>

        <local-cache name="users">
            <encoding>
                <key media-type="application/x-java-object"/>
                <value media-type="application/x-java-object"/>
            </encoding>
            <memory max-count="10000"/>
        </local-cache>

        <local-cache name="authorization">
            <encoding>
                <key media-type="application/x-java-object"/>
                <value media-type="application/x-java-object"/>
            </encoding>
            <memory max-count="10000"/>
        </local-cache>

        <local-cache name="keys">
            <encoding>
                <key media-type="application/x-java-object"/>
                <value media-type="application/x-java-object"/>
            </encoding>
            <expiration max-idle="3600000"/>
            <memory max-count="1000"/>
        </local-cache>

        <local-cache name="crl">
            <encoding>
                <key media-type="application/x-java-object"/>
                <value media-type="application/x-java-object"/>
            </encoding>
            <memory max-count="1000"/>
        </local-cache>

        <!-- Distributed session caches — owners=2 mirrors to the other node -->
        <distributed-cache name="sessions" owners="2">
            <expiration lifespan="-1"/>
        </distributed-cache>

        <distributed-cache name="authenticationSessions" owners="2">
            <expiration lifespan="-1"/>
        </distributed-cache>

        <distributed-cache name="offlineSessions" owners="2">
            <expiration lifespan="-1"/>
        </distributed-cache>

        <distributed-cache name="clientSessions" owners="2">
            <expiration lifespan="-1"/>
        </distributed-cache>

        <distributed-cache name="offlineClientSessions" owners="2">
            <expiration lifespan="-1"/>
        </distributed-cache>

        <distributed-cache name="loginFailures" owners="2">
            <expiration lifespan="-1"/>
        </distributed-cache>

        <distributed-cache name="actionTokens" owners="2">
            <encoding>
                <key media-type="application/x-java-object"/>
                <value media-type="application/x-java-object"/>
            </encoding>
            <expiration lifespan="-1" max-idle="-1"/>
        </distributed-cache>

        <distributed-cache name="work" owners="2">
            <expiration lifespan="-1"/>
        </distributed-cache>
    </cache-container>
</infinispan>
