{
  "title": "Personel — Agent Health",
  "uid": "personel-agents-health",
  "tags": ["personel", "agents"],
  "timezone": "browser",
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Active Agents",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [{
        "expr": "count(personel_agent_last_heartbeat_ts > (time() - 300))",
        "legendFormat": "Active"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "title": "Offline Agents (>5 min)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [{
        "expr": "count(time() - personel_agent_last_heartbeat_ts > 300) OR vector(0)",
        "legendFormat": "Offline"
      }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{"color":"green","value":0},{"color":"yellow","value":1},{"color":"red","value":10}] } } }
    },
    {
      "id": 3,
      "title": "Events/s (all agents)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{
        "expr": "sum(rate(personel_gateway_events_ingested_total[1m]))",
        "legendFormat": "Events/s"
      }]
    },
    {
      "id": 4,
      "title": "Agent Versions",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 4 },
      "targets": [{
        "expr": "count by (agent_version) (personel_agent_info)",
        "legendFormat": "{{agent_version}}"
      }]
    },
    {
      "id": 5,
      "title": "Heartbeat Alerts",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [{
        "expr": "sort_desc(time() - max by (endpoint_id, tenant_id) (personel_agent_last_heartbeat_ts))",
        "legendFormat": "{{endpoint_id}}",
        "format": "table",
        "instant": true
      }]
    }
  ]
}
