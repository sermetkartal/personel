# =============================================================================
# Personel Platform — Environment Variables
# =============================================================================
# TR: Bu dosyayı ".env" olarak kopyalayın ve CHANGEME değerlerini güncelleyin.
#     Gerçek sırları bu dosyaya YAZMAYIN. Vault ile yönetilirler.
# EN: Copy this file to ".env" and update all CHANGEME values.
#     Do NOT put real secrets here — they are managed by Vault.
#
# Kullanım / Usage:
#   cp .env.example .env
#   chmod 600 .env
#   # edit .env with your values
# =============================================================================

# -----------------------------------------------------------------------------
# STACK IDENTITY
# TR: Bu kuruluma özgü kiracı kimliği ve ortam adı.
# EN: Tenant identity unique to this installation.
# -----------------------------------------------------------------------------
PERSONEL_TENANT_ID=changeme-tenant-uuid
PERSONEL_ENV=production
PERSONEL_VERSION=0.1.0

# Internal domain used for service-to-service DNS inside Docker networks.
PERSONEL_INTERNAL_DOMAIN=personel.internal

# External FQDN that the admin console, portal, and agent will reach the server on.
# Must have a valid TLS cert (issued by Vault PKI or a commercial CA).
PERSONEL_EXTERNAL_HOST=personel.example.com

# -----------------------------------------------------------------------------
# POSTGRES
# TR: Uygulama için veritabanı bağlantı bilgileri. Şifreler Vault tarafından döndürülür.
# EN: PostgreSQL connection settings. Passwords are rotated by Vault dynamic secrets.
# -----------------------------------------------------------------------------
POSTGRES_DB=personel
POSTGRES_USER=postgres
# CHANGEME: superuser password — sealed in break-glass envelope after first run.
POSTGRES_PASSWORD=CHANGEME_POSTGRES_SUPERUSER

# Application roles (Vault dynamic secrets engine — do not hardcode in production)
POSTGRES_APP_USER=app_admin_api
POSTGRES_APP_PASSWORD=CHANGEME_VAULT_DYNAMIC_SECRET
POSTGRES_GATEWAY_USER=app_gateway
POSTGRES_GATEWAY_PASSWORD=CHANGEME_VAULT_DYNAMIC_SECRET
POSTGRES_DLP_RO_USER=app_dlp_ro
POSTGRES_DLP_RO_PASSWORD=CHANGEME_VAULT_DYNAMIC_SECRET

POSTGRES_PORT=5432
POSTGRES_DATA_DIR=/var/lib/personel/postgres/data
POSTGRES_MAX_CONNECTIONS=200
POSTGRES_SHARED_BUFFERS=2GB
POSTGRES_EFFECTIVE_CACHE_SIZE=6GB
POSTGRES_WORK_MEM=64MB

# -----------------------------------------------------------------------------
# CLICKHOUSE
# TR: Zaman serisi olay deposu.
# EN: Time-series event store.
# -----------------------------------------------------------------------------
CLICKHOUSE_DB=personel
CLICKHOUSE_USER=personel_app
# CHANGEME: ClickHouse application password
CLICKHOUSE_PASSWORD=CHANGEME_CLICKHOUSE_APP_PASSWORD
CLICKHOUSE_ADMIN_USER=default
CLICKHOUSE_ADMIN_PASSWORD=CHANGEME_CLICKHOUSE_ADMIN_PASSWORD
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_DATA_DIR=/var/lib/personel/clickhouse/data

# Phase 1 single-node (MergeTree). Shard/replica macros are placeholders
# for Phase-1-exit migration to ReplicatedMergeTree.
CLICKHOUSE_REPLICA_ID=replica-01
CLICKHOUSE_SHARD_ID=shard-01
CLICKHOUSE_CLUSTER_NAME=personel_cluster

# -----------------------------------------------------------------------------
# NATS JetStream
# TR: Olay akış otobüsü. JetStream aktif, TLS zorunlu.
# EN: Event streaming bus. JetStream enabled, TLS required.
# -----------------------------------------------------------------------------
NATS_PORT=4222
NATS_CLUSTER_PORT=6222
NATS_MONITOR_PORT=8222
# CHANGEME: NATS operator JWT (generated by nsc)
NATS_OPERATOR_JWT=CHANGEME_NATS_OPERATOR_JWT
# At-rest encryption passphrase for JetStream store
# CHANGEME: 32-byte hex or base64 random value
NATS_STORE_ENCRYPTION_KEY=CHANGEME_NATS_STORE_KEY_32BYTES_HEX

# NATS user credentials (NKey seed — delivered via Vault KV in production)
NATS_GATEWAY_CREDS=CHANGEME_NATS_GATEWAY_CREDS_PATH
NATS_DLP_CREDS=CHANGEME_NATS_DLP_CREDS_PATH
NATS_API_CREDS=CHANGEME_NATS_API_CREDS_PATH
NATS_AUDIT_CREDS=CHANGEME_NATS_AUDIT_CREDS_PATH

NATS_MAX_PAYLOAD=8MB
NATS_MAX_FILE_STORE=50GB
NATS_MAX_MEM_STORE=4GB

# -----------------------------------------------------------------------------
# MINIO
# TR: Nesne depolama (ekran görüntüleri, klavye şifreli bloblar, yedekler).
# EN: Object storage for screenshots, encrypted keystroke blobs, backups.
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
# CHANGEME: MinIO root password — sealed in break-glass envelope.
MINIO_ROOT_PASSWORD=CHANGEME_MINIO_ROOT_PASSWORD
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_DATA_DIR=/var/lib/personel/minio/data
# Internal service access keys (Vault-rotated in production)
MINIO_GATEWAY_ACCESS_KEY=CHANGEME_MINIO_GW_ACCESS_KEY
MINIO_GATEWAY_SECRET_KEY=CHANGEME_MINIO_GW_SECRET_KEY
MINIO_DLP_ACCESS_KEY=CHANGEME_MINIO_DLP_ACCESS_KEY
MINIO_DLP_SECRET_KEY=CHANGEME_MINIO_DLP_SECRET_KEY
MINIO_BACKUP_ACCESS_KEY=CHANGEME_MINIO_BACKUP_ACCESS_KEY
MINIO_BACKUP_SECRET_KEY=CHANGEME_MINIO_BACKUP_SECRET_KEY

# Bucket names
MINIO_BUCKET_SCREENSHOTS=screenshots
MINIO_BUCKET_KEYSTROKE_BLOBS=keystroke-blobs
MINIO_BUCKET_SCREEN_CLIPS=screen-clips
MINIO_BUCKET_DSR_RESPONSES=dsr-responses
MINIO_BUCKET_DESTRUCTION_REPORTS=destruction-reports
MINIO_BUCKET_BACKUPS=backups

# -----------------------------------------------------------------------------
# OPENSEARCH
# TR: Tam metin arama ve denetim logu arama.
# EN: Full-text search and audit log search.
# -----------------------------------------------------------------------------
OPENSEARCH_PORT=9200
OPENSEARCH_DASHBOARD_PORT=5601
OPENSEARCH_ADMIN_USER=admin
# CHANGEME: OpenSearch admin password (min 8 chars, upper+lower+digit+special)
OPENSEARCH_ADMIN_PASSWORD=CHANGEME_OPENSEARCH_ADMIN_PASSWORD
OPENSEARCH_DATA_DIR=/var/lib/personel/opensearch/data
# Java heap — set to half available RAM up to 31GB
OPENSEARCH_JAVA_OPTS=-Xms2g -Xmx2g

# -----------------------------------------------------------------------------
# KEYCLOAK (IAM / SSO)
# TR: Kimlik ve erişim yönetimi. Yönetici konsolu, portal ve API istemcileri.
# EN: Identity and access management.
# -----------------------------------------------------------------------------
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN_USER=admin
# CHANGEME: Keycloak admin password
KEYCLOAK_ADMIN_PASSWORD=CHANGEME_KEYCLOAK_ADMIN_PASSWORD
KEYCLOAK_DB_URL=jdbc:postgresql://postgres:5432/personel_keycloak
KEYCLOAK_DB_USER=app_keycloak
# CHANGEME: Keycloak DB password (Vault dynamic secret in production)
KEYCLOAK_DB_PASSWORD=CHANGEME_KEYCLOAK_DB_PASSWORD
KEYCLOAK_REALM=personel
KEYCLOAK_DATA_DIR=/var/lib/personel/keycloak/data

# SMTP for notifications (DSR, DPO alerts, etc.)
KEYCLOAK_SMTP_HOST=CHANGEME_SMTP_HOST
KEYCLOAK_SMTP_PORT=587
KEYCLOAK_SMTP_USER=CHANGEME_SMTP_USER
KEYCLOAK_SMTP_PASSWORD=CHANGEME_SMTP_PASSWORD
KEYCLOAK_SMTP_FROM=noreply@CHANGEME_YOUR_DOMAIN

# -----------------------------------------------------------------------------
# VAULT
# TR: Sır yönetimi, PKI, anahtar hiyerarşisi.
# EN: Secrets management, PKI, key hierarchy.
# -----------------------------------------------------------------------------
VAULT_PORT=8200
VAULT_CLUSTER_PORT=8201
VAULT_ADDR=https://vault.personel.internal:8200
# CHANGEME: Vault TLS cert paths (auto-bootstrapped by install.sh)
VAULT_TLS_CERT=/etc/personel/tls/vault.crt
VAULT_TLS_KEY=/etc/personel/tls/vault.key
VAULT_DATA_DIR=/var/lib/personel/vault/data
VAULT_LOG_LEVEL=info
# AppRole Role IDs (not secret — role IDs are not sensitive)
VAULT_ROLE_ID_GATEWAY=CHANGEME_VAULT_GATEWAY_ROLE_ID
VAULT_ROLE_ID_API=CHANGEME_VAULT_API_ROLE_ID
VAULT_ROLE_ID_DLP=CHANGEME_VAULT_DLP_ROLE_ID
# Secret IDs are delivered via systemd credentials — NEVER in env vars

# -----------------------------------------------------------------------------
# GATEWAY SERVICE
# TR: Ajan mTLS ingest noktası.
# EN: Agent mTLS ingest endpoint.
# -----------------------------------------------------------------------------
GATEWAY_GRPC_PORT=9443
GATEWAY_METRICS_PORT=9090
GATEWAY_LOG_LEVEL=info
# mTLS server cert paths (written by vault-agent sidecar)
GATEWAY_TLS_CERT=/etc/personel/tls/gateway.crt
GATEWAY_TLS_KEY=/etc/personel/tls/gateway.key
GATEWAY_CA_BUNDLE=/etc/personel/tls/tenant_ca.crt
# Denial-of-service limits
GATEWAY_MAX_CONN_PER_AGENT=2
GATEWAY_MAX_BATCH_SIZE_BYTES=4194304
GATEWAY_RATE_LIMIT_EVENTS_PER_SEC=1000

# -----------------------------------------------------------------------------
# ADMIN API
# TR: Yönetici REST/gRPC API'si.
# EN: Admin REST/gRPC API.
# -----------------------------------------------------------------------------
API_HTTP_PORT=8000
API_GRPC_PORT=9000
API_METRICS_PORT=9091
API_LOG_LEVEL=info
# JWT signing key kid (actual key material in Vault transit)
API_JWT_KID=personel-api-v1
API_JWT_ISSUER=https://CHANGEME_YOUR_DOMAIN/auth/realms/personel
API_JWT_ACCESS_TTL=900
API_JWT_REFRESH_TTL=86400

# DSR SLA configuration (KVKK m.11)
DSR_SLA_WARN_DAYS=20
DSR_SLA_OVERDUE_DAYS=30
DSR_SLA_EXTENSION_MAX_DAYS=30
DPO_EMAIL=CHANGEME_DPO_EMAIL
DPO_SECONDARY_EMAIL=CHANGEME_DPO_SECONDARY_EMAIL

# -----------------------------------------------------------------------------
# DLP SERVICE
# TR: Klavye içeriği şifre çözme ve desen eşleme. Izole konteyner.
# EN: Keystroke decryption and pattern matching. Isolated container.
# -----------------------------------------------------------------------------
DLP_METRICS_PORT=9092
DLP_LOG_LEVEL=info
DLP_WORKER_COUNT=4
DLP_BATCH_SIZE=50
DLP_MEMGUARD_ENABLED=true
# GODEBUG settings for memory hygiene
DLP_GODEBUG=madvdontneed=1
# Vault AppRole Role ID (not secret)
DLP_VAULT_ROLE_ID=CHANGEME_VAULT_DLP_ROLE_ID
# NATS subjects
DLP_NATS_SUBSCRIBE_SUBJECT=events.v1.keystroke.content_encrypted.*
DLP_NATS_PUBLISH_SUBJECT=dlp.v1.match

# -----------------------------------------------------------------------------
# LIVEKIT SFU
# TR: WebRTC ekran paylaşım oturumları.
# EN: WebRTC screen share sessions.
# -----------------------------------------------------------------------------
LIVEKIT_PORT=7880
LIVEKIT_RTC_UDP_PORT_MIN=50000
LIVEKIT_RTC_UDP_PORT_MAX=60000
# CHANGEME: LiveKit API key and secret (Vault-rotated in production)
LIVEKIT_API_KEY=CHANGEME_LIVEKIT_API_KEY
LIVEKIT_API_SECRET=CHANGEME_LIVEKIT_API_SECRET

# -----------------------------------------------------------------------------
# CONSOLE / PORTAL (Next.js)
# TR: Yönetici konsolu ve şeffaflık portalı.
# EN: Admin console and transparency portal.
# -----------------------------------------------------------------------------
CONSOLE_PORT=3000
PORTAL_PORT=3001
NEXTAUTH_SECRET=CHANGEME_NEXTAUTH_SECRET_32BYTES
NEXTAUTH_URL=https://CHANGEME_YOUR_DOMAIN
NEXT_PUBLIC_API_URL=https://CHANGEME_YOUR_DOMAIN/api
NEXT_PUBLIC_TENANT_ID=${PERSONEL_TENANT_ID}

# -----------------------------------------------------------------------------
# PROMETHEUS / GRAFANA
# TR: Gözlemlenebilirlik altyapısı.
# EN: Observability stack.
# -----------------------------------------------------------------------------
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=30d
PROMETHEUS_DATA_DIR=/var/lib/personel/prometheus/data
GRAFANA_PORT=3002
GRAFANA_DATA_DIR=/var/lib/personel/grafana/data
GRAFANA_ADMIN_USER=admin
# CHANGEME: Grafana admin password
GRAFANA_ADMIN_PASSWORD=CHANGEME_GRAFANA_ADMIN_PASSWORD

# -----------------------------------------------------------------------------
# ENVOY EDGE PROXY
# TR: Ön uç TLS sonlandırma ve yük dengeleme.
# EN: Edge TLS termination and load balancing.
# -----------------------------------------------------------------------------
ENVOY_HTTP_PORT=80
ENVOY_HTTPS_PORT=443
ENVOY_ADMIN_PORT=9901

# -----------------------------------------------------------------------------
# BACKUP
# TR: Yedekleme şifreleme ve depolama ayarları.
# EN: Backup encryption and storage settings.
# -----------------------------------------------------------------------------
BACKUP_DIR=/var/lib/personel/backups
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
BACKUP_RETENTION_MONTHLY=12
# CHANGEME: GPG passphrase for backup encryption.
# Generate with: openssl rand -base64 32
BACKUP_GPG_PASSPHRASE=CHANGEME_BACKUP_GPG_PASSPHRASE
# Optional: asymmetric backup recipient key fingerprint
BACKUP_GPG_RECIPIENT=CHANGEME_GPG_FINGERPRINT_OR_LEAVE_EMPTY
# age encryption public key (alternative to GPG)
BACKUP_AGE_RECIPIENT=CHANGEME_AGE_PUBLIC_KEY

# -----------------------------------------------------------------------------
# TLS / PKI
# TR: Sertifika yolları. install.sh tarafından otomatik doldurulur.
# EN: Certificate paths. Populated automatically by install.sh.
# -----------------------------------------------------------------------------
TLS_DIR=/etc/personel/tls
ROOT_CA_CERT=/etc/personel/tls/root_ca.crt
TENANT_CA_CERT=/etc/personel/tls/tenant_ca.crt

# -----------------------------------------------------------------------------
# AUDIT / COMPLIANCE
# TR: Denetim günlüğü ve KVKK uyum ayarları.
# EN: Audit log and KVKK compliance settings.
# -----------------------------------------------------------------------------
AUDIT_LOG_DIR=/var/log/personel/audit
AUDIT_CHECKPOINT_INTERVAL=3600
# Destruction report schedule (cron syntax, local time)
DESTRUCTION_REPORT_SCHEDULE_H1="0 0 1 1 *"
DESTRUCTION_REPORT_SCHEDULE_H2="0 0 1 7 *"

# -----------------------------------------------------------------------------
# RESOURCE LIMITS (sized for 16c/64GB host)
# TR: Konteyner kaynak limitleri. Toplam hedef host kapasitesinin %80'i.
# EN: Container resource limits. Total target 80% of host capacity.
# -----------------------------------------------------------------------------
POSTGRES_CPUS=4
POSTGRES_MEM=8g
CLICKHOUSE_CPUS=4
CLICKHOUSE_MEM=16g
NATS_CPUS=2
NATS_MEM=4g
MINIO_CPUS=2
MINIO_MEM=4g
OPENSEARCH_CPUS=2
OPENSEARCH_MEM=4g
VAULT_CPUS=1
VAULT_MEM=1g
GATEWAY_CPUS=2
GATEWAY_MEM=2g
API_CPUS=2
API_MEM=2g
DLP_CPUS=2
DLP_MEM=2g
ENRICHER_CPUS=1
ENRICHER_MEM=1g
KEYCLOAK_CPUS=2
KEYCLOAK_MEM=2g
CONSOLE_CPUS=1
CONSOLE_MEM=1g
PORTAL_CPUS=1
PORTAL_MEM=512m
LIVEKIT_CPUS=2
LIVEKIT_MEM=2g
PROMETHEUS_CPUS=1
PROMETHEUS_MEM=2g
GRAFANA_CPUS=1
GRAFANA_MEM=512m
ENVOY_CPUS=1
ENVOY_MEM=512m
