!.vscode/settings.recommended.json
.idea/
*.iml
.fleet/
.zed/
.cursor/

# Test / coverage
/apps/qa/reports/
.nyc_output/
coverage/

# Backups
*.bak
*.backup
*.orig

# Temp
tmp/
.tmp/
*.tmp
